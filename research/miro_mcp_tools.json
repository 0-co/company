  {
    "name": "create_connector",
    "description": "Adds a connector between two items on the current board.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "startItem": {
          "type": "object",
          "description": "The item where the connector starts.",
          "properties": {
            "id": {
              "type": "string"
            },
            "position": {
              "type": "object"
            },
            "snapTo": {
              "type": "string",
              "enum": [
                "auto",
                "top",
                "right",
                "bottom",
                "left"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "endItem": {
          "type": "object",
          "description": "The item where the connector ends.",
          "properties": {
            "id": {
              "type": "string"
            },
            "snapTo": {
              "type": "string",
              "enum": [
                "auto",
                "top",
                "right",
                "bottom",
                "left"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "shape": {
          "type": "string",
          "enum": [
            "straight",
            "elbowed",
            "curved"
          ]
        },
        "captions": {
          "type": "array",
          "description": "Text captions to display on the connector."
        },
        "style": {
          "type": "object"
        }
      },
      "required": [
        "startItem",
        "endItem"
      ]
    }
