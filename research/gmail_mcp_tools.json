  {
    "name": "create_filter",
    "description": "Creates a new Gmail filter with custom criteria and actions",
    "inputSchema": {
      "type": "object",
      "properties": {
        "criteria": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "subject": {
              "type": "string"
            },
            "query": {
              "type": "string"
            },
            "hasAttachment": {
              "type": "boolean"
            },
            "size": {
              "type": "number"
            },
            "sizeComparison": {
              "type": "string",
              "enum": [
                "unspecified",
                "smaller",
                "larger"
              ]
            }
          }
        },
        "action": {
          "type": "object",
          "properties": {
            "addLabelIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removeLabelIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "forward": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "criteria",
        "action"
      ]
    }
  },
