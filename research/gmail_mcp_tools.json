          "type": "string"
        },
        "attachmentId": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "savePath": {
          "type": "string"
        }
      },
      "required": [
        "messageId",
        "attachmentId"
      ]
    }
  }
