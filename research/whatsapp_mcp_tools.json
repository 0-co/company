[
  {
    "name": "search_contacts",
    "description": "Search WhatsApp contacts by name or phone number.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search term to match against contact names or phone numbers"
        }
      },
      "required": ["query"]
    }
  },
  {
    "name": "list_messages",
    "description": "Get WhatsApp messages matching specified criteria with optional context.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "after": {
          "type": "string",
          "description": "ISO-8601 formatted string for messages after this date"
        },
        "before": {
          "type": "string",
          "description": "ISO-8601 formatted string for messages before this date"
        },
        "sender_phone_number": {
          "type": "string",
          "description": "Filter messages by sender"
        },
        "chat_jid": {
          "type": "string",
          "description": "Filter messages by chat"
        },
        "query": {
          "type": "string",
          "description": "Search term to filter by content"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum messages to return",
          "default": 20
        },
        "page": {
          "type": "integer",
          "description": "Pagination page number",
          "default": 0
        },
        "include_context": {
          "type": "boolean",
          "description": "Include surrounding messages",
          "default": true
        },
        "context_before": {
          "type": "integer",
          "description": "Messages to include before matches",
          "default": 1
        },
        "context_after": {
          "type": "integer",
          "description": "Messages to include after matches",
          "default": 1
        }
      },
      "required": []
    }
  },
  {
    "name": "list_chats",
    "description": "Get WhatsApp chats matching specified criteria.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search term for chat names or JID"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum chats to return",
          "default": 20
        },
        "page": {
          "type": "integer",
          "description": "Pagination page number",
          "default": 0
        },
        "include_last_message": {
          "type": "boolean",
          "description": "Include final message in each chat",
          "default": true
        },
        "sort_by": {
          "type": "string",
          "description": "Sort by 'last_active' or 'name'",
          "enum": ["last_active", "name"],
          "default": "last_active"
        }
      },
      "required": []
    }
  },
  {
    "name": "get_chat",
    "description": "Get WhatsApp chat metadata by JID.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "chat_jid": {
          "type": "string",
          "description": "The JID of the chat to retrieve"
        },
        "include_last_message": {
          "type": "boolean",
          "description": "Include final message",
          "default": true
        }
      },
      "required": ["chat_jid"]
    }
  },
  {
    "name": "get_direct_chat_by_contact",
    "description": "Get WhatsApp chat metadata by sender phone number.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "sender_phone_number": {
          "type": "string",
          "description": "Phone number to search for"
        }
      },
      "required": ["sender_phone_number"]
    }
  },
  {
    "name": "get_contact_chats",
    "description": "Get all WhatsApp chats involving the contact.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "jid": {
          "type": "string",
          "description": "Contact's JID to search for"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum chats to return",
          "default": 20
        },
        "page": {
          "type": "integer",
          "description": "Pagination page number",
          "default": 0
        }
      },
      "required": ["jid"]
    }
  },
  {
    "name": "get_last_interaction",
    "description": "Get most recent WhatsApp message involving the contact.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "jid": {
          "type": "string",
          "description": "Contact's JID to search for"
        }
      },
      "required": ["jid"]
    }
  },
  {
    "name": "get_message_context",
    "description": "Get context around a specific WhatsApp message.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string",
          "description": "ID of the message to get context for"
        },
        "before": {
          "type": "integer",
          "description": "Messages to include prior",
          "default": 5
        },
        "after": {
          "type": "integer",
          "description": "Messages to include after",
          "default": 5
        }
      },
      "required": ["message_id"]
    }
  },
  {
    "name": "send_message",
    "description": "Send a WhatsApp message to a person or group. For group chats use the JID.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "recipient": {
          "type": "string",
          "description": "Phone number with country code (no symbols) or JID"
        },
        "message": {
          "type": "string",
          "description": "Text content to send"
        }
      },
      "required": ["recipient", "message"]
    }
  },
  {
    "name": "send_file",
    "description": "Send a file such as a picture, raw audio, video or document via WhatsApp.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "recipient": {
          "type": "string",
          "description": "Phone number with country code (no symbols) or JID"
        },
        "media_path": {
          "type": "string",
          "description": "Absolute path to media file"
        }
      },
      "required": ["recipient", "media_path"]
    }
  },
  {
    "name": "send_audio_message",
    "description": "Send any audio file as a WhatsApp audio message.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "recipient": {
          "type": "string",
          "description": "Phone number with country code (no symbols) or JID"
        },
        "media_path": {
          "type": "string",
          "description": "Absolute path to audio file (converts to Opus .ogg if needed)"
        }
      },
      "required": ["recipient", "media_path"]
    }
  },
  {
    "name": "download_media",
    "description": "Download media from a WhatsApp message and get the local file path.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "message_id": {
          "type": "string",
          "description": "ID of the message containing media"
        },
        "chat_jid": {
          "type": "string",
          "description": "JID of the chat containing the message"
        }
      },
      "required": ["message_id", "chat_jid"]
    }
  }
]
