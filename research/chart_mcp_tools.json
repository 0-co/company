[
  {
    "name": "generate_area_chart",
    "description": "Generate a area chart to show data trends under continuous independent variables and observe the overall data trend, such as, displacement = velocity (average or instantaneous) × time: s = v × t. If the x-axis is time (t) and the y-axis is velocity (v) at each moment, an area chart allows you to observe the trend of velocity over time and infer the distance traveled by the area's size.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string" },
              "value": { "type": "number" },
              "group": { "type": "string" }
            },
            "required": ["time", "value"]
          },
          "description": "Data for area chart. Array of objects with time, value, and optional group fields.",
          "minItems": 1
        },
        "stack": {
          "type": "boolean",
          "description": "Enable stacking when group field is present in data",
          "default": false
        },
        "style": {
          "type": "object",
          "properties": {
            "backgroundColor": { "type": "string" },
            "palette": { "type": "array", "items": { "type": "string" } },
            "texture": { "type": "string", "enum": ["default", "rough"] },
            "lineWidth": { "type": "number" }
          }
        },
        "theme": {
          "type": "string",
          "enum": ["default", "academy", "dark"],
          "description": "Visual theme of the chart",
          "default": "default"
        },
        "width": {
          "type": "number",
          "description": "Chart width in pixels",
          "default": 600
        },
        "height": {
          "type": "number",
          "description": "Chart height in pixels",
          "default": 400
        },
        "title": {
          "type": "string",
          "description": "Chart title",
          "default": ""
        },
        "axisXTitle": {
          "type": "string",
          "description": "X-axis label",
          "default": ""
        },
        "axisYTitle": {
          "type": "string",
          "description": "Y-axis label",
          "default": ""
        }
      },
      "required": ["data"]
    }
  },
  {
