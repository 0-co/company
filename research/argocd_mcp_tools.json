        "propagationPolicy": {"type": "string", "description": "Deletion propagation policy (e.g., 'foreground', 'background', 'orphan')"}
      },
      "required": ["applicationName"]
    }
  },
  {
    "name": "sync_application",
    "description": "Sync an ArgoCD application with its target state.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application to sync"},
        "applicationNamespace": {"type": "string", "description": "Namespace of the application (optional)"},
        "dryRun": {"type": "boolean", "description": "Whether to perform a dry run sync without applying changes"},
        "prune": {"type": "boolean", "description": "Whether to delete resources not in the desired state"},
        "revision": {"type": "string", "description": "Git revision to sync to (branch, tag, or commit hash)"},
        "syncOptions": {"type": "array", "items": {"type": "string"}, "description": "List of sync options to apply"}
      },
      "required": ["applicationName"]
    }
  },
  {
    "name": "run_resource_action",
    "description": "Run a resource action on a specific resource within an ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application"},
        "applicationNamespace": {"type": "string", "description": "Namespace of the application"},
        "resourceRef": {"type": "object", "description": "Reference to the resource (kind, name, namespace)"},
        "action": {"type": "string", "description": "Name of the action to run on the resource"}
