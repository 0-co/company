      },
      "required": ["applicationName", "applicationNamespace", "resourceUID", "resourceNamespace", "resourceName"]
    }
  },
  {
    "name": "get_resources",
    "description": "Get resource manifests for resources managed by an ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application"},
