[
  {
    "name": "list_applications",
    "description": "List ArgoCD applications with optional filtering.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "search": {"type": "string", "description": "Optional partial match to filter applications by name"},
        "limit": {"type": "number", "description": "Optional maximum number of applications to return"},
        "offset": {"type": "number", "description": "Optional number of applications to skip for pagination"}
      }
    }
  },
  {
    "name": "get_application",
    "description": "Get details about a specific ArgoCD application by name.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application to retrieve"},
        "applicationNamespace": {"type": "string", "description": "Namespace of the application (optional)"}
      },
      "required": ["applicationName"]
    }
  },
  {
    "name": "get_application_resource_tree",
    "description": "Get the resource tree for an ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application"}
      },
      "required": ["applicationName"]
    }
  },
  {
    "name": "get_application_managed_resources",
