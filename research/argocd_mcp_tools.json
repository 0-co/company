    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application"},
        "kind": {"type": "string", "description": "Filter by resource kind (e.g., 'ConfigMap', 'Deployment')"},
        "namespace": {"type": "string", "description": "Filter by namespace"},
        "name": {"type": "string", "description": "Filter by resource name"},
        "version": {"type": "string", "description": "Filter by API version"},
        "group": {"type": "string", "description": "Filter by API group"}
      },
      "required": ["applicationName"]
    }
  },
  {
    "name": "get_application_workload_logs",
    "description": "Get logs from a workload managed by an ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application"},
