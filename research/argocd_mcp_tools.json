        "resourceRef": {"type": "object", "description": "Reference to the resource (kind, name, namespace)"}
      },
      "required": ["applicationName", "applicationNamespace", "resourceRef"]
    }
  },
  {
    "name": "create_application",
    "description": "Create a new ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "application": {"type": "object", "description": "Application specification object (ArgoCD Application manifest)"}
      },
      "required": ["application"]
    }
  },
  {
    "name": "update_application",
