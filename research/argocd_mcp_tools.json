      "required": ["applicationName", "application"]
    }
  },
  {
    "name": "delete_application",
    "description": "Delete an ArgoCD application.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationName": {"type": "string", "description": "Name of the application to delete"},
