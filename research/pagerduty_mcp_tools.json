[
  {
    "name": "list_incidents",
    "description": "List incidents with optional filtering.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "triggered",
              "acknowledged",
              "resolved"
            ]
          },
          "description": "Filter incidents by status"
        },
        "since": {
          "type": "string",
          "description": "Filter incidents since a specific date (ISO 8601 datetime)"
        },
        "until": {
          "type": "string",
          "description": "Filter incidents until a specific date (ISO 8601 datetime)"
        },
        "user_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Filter incidents by user IDs"
        },
        "service_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Filter incidents by service IDs"
        },
        "teams_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Filter incidents by team IDs"
        },
        "urgencies": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "high",
              "low"
            ]
          },
          "description": "Filter incidents by urgency"
        },
        "request_scope": {
          "type": "string",
          "enum": [
            "all",
            "teams",
            "assigned"
          ],
          "description": "Filter incidents by request scope. Either all, my teams or assigned to me",
          "default": "all"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results to return. The maximum is 1000",
          "minimum": 1,
          "maximum": 1000
        },
        "sort_by": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "incident_number:asc",
              "incident_number:desc",
              "created_at:asc",
              "created_at:desc",
              "resolved_at:asc",
              "resolved_at:desc",
              "urgency:asc",
              "urgency:desc"
            ]
          },
          "description": "Sort field and direction, separated by colon. Maximum two fields."
        }
      },
      "required": []
    }
  },
  {
