[
  {
    "name": "auth0_list_applications",
    "description": "List all applications in the Auth0 tenant or search by name",
    "inputSchema": {
      "type": "object",
      "properties": {
        "page": {"type": "number", "description": "Page number (0-based)"},
        "per_page": {"type": "number", "description": "Number of applications per page"},
        "include_totals": {"type": "boolean", "description": "Include total count in response"}
      }
    }
  },
  {
    "name": "auth0_get_application",
    "description": "Get details about a specific Auth0 application",
    "inputSchema": {
      "type": "object",
      "properties": {
        "client_id": {"type": "string", "description": "Client ID of the application to retrieve"}
      },
      "required": ["client_id"]
    }
  },
  {
    "name": "auth0_create_application",
    "description": "Create a new Auth0 application. Prefer OIDC compliant unless otherwise specified.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "description": "Name of the application"},
        "app_type": {"type": "string", "enum": ["spa", "native", "non_interactive", "regular_web"], "description": "Type of application"},
        "description": {"type": "string", "description": "Description of the application"},
        "callbacks": {"type": "array", "items": {"type": "string"}, "description": "Allowed callback URLs"},
        "allowed_origins": {"type": "array", "items": {"type": "string"}, "description": "Allowed CORS origins"},
        "allowed_logout_urls": {"type": "array", "items": {"type": "string"}, "description": "Allowed logout URLs"},
        "is_first_party": {"type": "boolean", "description": "Whether this is a first-party application"},
        "oidc_conformant": {"type": "boolean", "description": "Whether to use OIDC-conformant behavior"},
        "logo_uri": {"type": "string", "description": "URL of the application logo"},
        "organization_usage": {"type": "string", "description": "Organization usage setting"},
        "organization_require_behavior": {"type": "string", "description": "Organization require behavior"}
      },
      "required": ["name"]
    }
  },
  {
    "name": "auth0_update_application",
    "description": "Update an existing Auth0 application",
    "inputSchema": {
      "type": "object",
      "properties": {
        "client_id": {"type": "string", "description": "Client ID of the application to update"},
        "name": {"type": "string", "description": "New name for the application"},
        "app_type": {"type": "string", "enum": ["spa", "native", "non_interactive", "regular_web"], "description": "Type of application"},
        "description": {"type": "string", "description": "Description of the application"},
        "callbacks": {"type": "array", "items": {"type": "string"}, "description": "Allowed callback URLs"},
        "allowed_origins": {"type": "array", "items": {"type": "string"}, "description": "Allowed CORS origins"},
        "allowed_logout_urls": {"type": "array", "items": {"type": "string"}, "description": "Allowed logout URLs"},
        "grant_types": {"type": "array", "items": {"type": "string"}, "description": "Allowed grant types"},
        "token_endpoint_auth_method": {"type": "string", "description": "Token endpoint authentication method"},
        "logo_uri": {"type": "string", "description": "URL of the application logo"}
      },
      "required": ["client_id"]
    }
  },
  {
    "name": "auth0_save_credentials_to_file",
    "description": "Save Auth0 application credentials to a file",
    "inputSchema": {
      "type": "object",
      "properties": {
        "client_id": {"type": "string", "description": "Client ID of the application"},
        "file_path": {"type": "string", "description": "File path to save credentials to"}
      },
      "required": ["client_id", "file_path"]
    }
  },
  {
    "name": "auth0_list_resource_servers",
    "description": "List all resource servers (APIs) in the Auth0 tenant",
    "inputSchema": {
      "type": "object",
      "properties": {
        "page": {"type": "number", "description": "Page number (0-based)"},
        "per_page": {"type": "number", "description": "Number of resource servers per page"},
        "include_totals": {"type": "boolean", "description": "Include total count"},
        "identifiers": {"type": "array", "items": {"type": "string"}, "description": "URI encoded identifiers to filter results"},
        "include_fields": {"type": "boolean", "description": "Include or exclude specified fields"}
      }
    }
  },
  {
    "name": "auth0_get_resource_server",
    "description": "Get details about a specific Auth0 resource server",
    "inputSchema": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "description": "ID of the resource server to retrieve"}
      },
      "required": ["id"]
    }
  },
  {
    "name": "auth0_create_resource_server",
    "description": "Create a new Auth0 resource server (API). Use RS256 for signing_alg unless otherwise specified.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "description": "Friendly name for the resource server"},
        "identifier": {"type": "string", "description": "Unique identifier (audience) for the API"},
        "scopes": {"type": "array", "items": {"type": "object"}, "description": "List of permissions with value and description"},
        "signing_alg": {"type": "string", "enum": ["HS256", "RS256", "PS256"], "description": "JWT signing algorithm"},
        "allow_offline_access": {"type": "boolean", "description": "Enable refresh tokens for offline access"},
        "token_lifetime": {"type": "number", "description": "Access token expiration in seconds"},
        "enforce_policies": {"type": "boolean", "description": "Enforce authorization policies"}
      },
      "required": ["name", "identifier"]
    }
  },
  {
    "name": "auth0_update_resource_server",
    "description": "Update an existing Auth0 resource server",
    "inputSchema": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "description": "ID of the resource server to update"},
        "name": {"type": "string", "description": "Friendly name for the resource server"},
        "scopes": {"type": "array", "items": {"type": "object"}, "description": "List of permissions with value and description"},
        "signing_alg": {"type": "string", "enum": ["HS256", "RS256", "PS256"], "description": "JWT signing algorithm"},
        "allow_offline_access": {"type": "boolean", "description": "Enable refresh tokens for offline access"},
        "token_lifetime": {"type": "number", "description": "Access token expiration in seconds"},
        "enforce_policies": {"type": "boolean", "description": "Enforce authorization policies"}
      },
      "required": ["id"]
    }
  },
  {
    "name": "auth0_create_application_grant",
    "description": "Create a client grant that authorizes an Auth0 application to access a specific API with defined scopes.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "client_id": {"type": "string", "description": "The ID of the application to authorize"},
        "audience": {"type": "string", "description": "The unique identifier (audience) of the API the application is being granted access to"},
        "scope": {"type": "array", "items": {"type": "string"}, "description": "List of permissions (scopes) granted to the application for the specified API"}
      },
      "required": ["client_id", "audience", "scope"]
    }
  },
