  {
    "name": "auth0_list_logs",
    "description": "List logs from the Auth0 tenant",
    "inputSchema": {
      "type": "object",
      "properties": {
        "from": {"type": "string", "description": "Log ID to start retrieving logs from (for pagination)"},
        "take": {"type": "number", "description": "Number of logs to retrieve (1-100, defaults to 50)"},
        "q": {"type": "string", "description": "Query in Lucene query string syntax for filtering logs"},
        "sort": {"type": "string", "enum": ["date:1", "date:-1"], "description": "Sort order by date (defaults to date:-1, newest first)"},
        "include_fields": {"type": "boolean", "description": "Whether to include all fields (defaults to true)"},
        "include_totals": {"type": "boolean", "description": "Whether to include total count (defaults to true)"}
      }
    }
  },
