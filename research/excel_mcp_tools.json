  },
  {
    "name": "create_pivot_table",
    "description": "Create pivot table in worksheet.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "filepath": {
          "type": "string",
          "description": "Path to Excel file"
        },
        "sheet_name": {
          "type": "string",
