  {
    "name": "analyze_diff",
    "description": "Analyze a git diff against IDE rules to identify rule violations.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "speedMode": {
          "type": "boolean",
          "default": false
        },
        "filterBy": {
          "type": "string",
          "enum": [
            "violations",
            "compliants",
            "humanReviewRequired",
            "none"
          ]
        },
        "diff": {
          "type": "string",
          "description": "Git diff content to analyze."
        },
        "rules": {
          "type": "string",
          "description": "Rules to use for analysis."
        }
      },
      "required": [
        "diff",
        "rules"
      ]
    }
  },
