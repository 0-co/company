  {
    "name": "search_feeds",
    "description": "\u641c\u7d22\u5c0f\u7ea2\u4e66\u5185\u5bb9\uff08\u9700\u8981\u5df2\u767b\u5f55\uff09",
    "inputSchema": {
      "type": "object",
      "properties": {
        "keyword": {
          "type": "string",
          "description": "\u641c\u7d22\u5173\u952e\u8bcd"
        },
        "filters": {
          "type": "object",
          "description": "\u7b5b\u9009\u9009\u9879",
          "properties": {
            "sort_by": {
              "type": "string",
              "description": "\u6392\u5e8f\u4f9d\u636e: \u7efc\u5408|\u6700\u65b0|\u6700\u591a\u70b9\u8d5e|\u6700\u591a\u8bc4\u8bba|\u6700\u591a\u6536\u85cf,\u9ed8\u8ba4\u4e3a'\u7efc\u5408'"
            },
            "note_type": {
              "type": "string",
              "description": "\u7b14\u8bb0\u7c7b\u578b: \u4e0d\u9650|\u89c6\u9891|\u56fe\u6587,\u9ed8\u8ba4\u4e3a'\u4e0d\u9650'"
            },
            "publish_time": {
              "type": "string",
              "description": "\u53d1\u5e03\u65f6\u95f4: \u4e0d\u9650|\u4e00\u5929\u5185|\u4e00\u5468\u5185|\u534a\u5e74\u5185,\u9ed8\u8ba4\u4e3a'\u4e0d\u9650'"
            },
            "search_scope": {
              "type": "string",
              "description": "\u641c\u7d22\u8303\u56f4: \u4e0d\u9650|\u5df2\u770b\u8fc7|\u672a\u770b\u8fc7|\u5df2\u5173\u6ce8,\u9ed8\u8ba4\u4e3a'\u4e0d\u9650'"
            },
            "location": {
              "type": "string",
              "description": "\u4f4d\u7f6e\u8ddd\u79bb: \u4e0d\u9650|\u540c\u57ce|\u9644\u8fd1,\u9ed8\u8ba4\u4e3a'\u4e0d\u9650'"
            }
          }
        }
      },
      "required": [
        "keyword"
      ]
    }
  },
  {
    "name": "get_feed_detail",
    "description": "\u83b7\u53d6\u5c0f\u7ea2\u4e66\u7b14\u8bb0\u8be6\u60c5\uff0c\u8fd4\u56de\u7b14\u8bb0\u5185\u5bb9\u3001\u56fe\u7247\u3001\u4f5c\u8005\u4fe1\u606f\u3001\u4e92\u52a8\u6570\u636e\uff08\u70b9\u8d5e/\u6536\u85cf/\u5206\u4eab\u6570\uff09\u53ca\u8bc4\u8bba\u5217\u8868\u3002\u9ed8\u8ba4\u8fd4\u56de\u524d10\u6761\u4e00\u7ea7\u8bc4\u8bba\uff0c\u5982\u9700\u66f4\u591a\u8bc4\u8bba\u8bf7\u8bbe\u7f6eload_all_comments=true",
    "inputSchema": {
      "type": "object",
      "properties": {
        "feed_id": {
          "type": "string",
          "description": "\u5c0f\u7ea2\u4e66\u7b14\u8bb0ID\uff0c\u4eceFeed\u5217\u8868\u83b7\u53d6"
        },
        "xsec_token": {
          "type": "string",
          "description": "\u8bbf\u95ee\u4ee4\u724c\uff0c\u4eceFeed\u5217\u8868\u7684xsecToken\u5b57\u6bb5\u83b7\u53d6"
        },
        "load_all_comments": {
          "type": "boolean",
          "description": "\u662f\u5426\u52a0\u8f7d\u5168\u90e8\u8bc4\u8bba\u3002false\u4ec5\u8fd4\u56de\u524d10\u6761\u4e00\u7ea7\u8bc4\u8bba\uff08\u9ed8\u8ba4\uff09\uff0ctrue\u6eda\u52a8\u52a0\u8f7d\u66f4\u591a\u8bc4\u8bba"
        },
        "limit": {
          "type": "integer",
          "description": "\u3010\u4ec5\u5f53load_all_comments\u4e3atrue\u65f6\u751f\u6548\u3011\u9650\u5236\u52a0\u8f7d\u7684\u4e00\u7ea7\u8bc4\u8bba\u6570\u91cf\u3002\u4f8b\u598220\u8868\u793a\u6700\u591a\u52a0\u8f7d20\u6761\uff0c\u9ed8\u8ba420"
        },
        "click_more_replies": {
          "type": "boolean",
          "description": "\u3010\u4ec5\u5f53load_all_comments\u4e3atrue\u65f6\u751f\u6548\u3011\u662f\u5426\u5c55\u5f00\u4e8c\u7ea7\u56de\u590d\u3002true\u5c55\u5f00\u5b50\u8bc4\u8bba\uff0cfalse\u4e0d\u5c55\u5f00\uff08\u9ed8\u8ba4\uff09"
        },
        "reply_limit": {
          "type": "integer",
          "description": "\u3010\u4ec5\u5f53click_more_replies\u4e3atrue\u65f6\u751f\u6548\u3011\u8df3\u8fc7\u56de\u590d\u6570\u8fc7\u591a\u7684\u8bc4\u8bba\u3002\u4f8b\u598210\u8868\u793a\u8df3\u8fc7\u8d85\u8fc710\u6761\u56de\u590d\u7684\uff0c\u9ed8\u8ba410"
        },
        "scroll_speed": {
          "type": "string",
          "description": "\u3010\u4ec5\u5f53load_all_comments\u4e3atrue\u65f6\u751f\u6548\u3011\u6eda\u52a8\u901f\u5ea6slow\u6162\u901f\u3001normal\u6b63\u5e38\u3001fast\u5feb\u901f"
        }
      },
      "required": [
        "feed_id",
        "xsec_token"
      ]
    }
  },
