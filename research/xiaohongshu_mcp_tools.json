  {
    "name": "publish_content",
    "description": "\u53d1\u5e03\u5c0f\u7ea2\u4e66\u56fe\u6587\u5185\u5bb9",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "\u5185\u5bb9\u6807\u9898\uff08\u5c0f\u7ea2\u4e66\u9650\u5236\uff1a\u6700\u591a20\u4e2a\u4e2d\u6587\u5b57\u6216\u82f1\u6587\u5355\u8bcd\uff09"
        },
        "content": {
          "type": "string",
          "description": "\u6b63\u6587\u5185\u5bb9\uff0c\u4e0d\u5305\u542b\u4ee5#\u5f00\u5934\u7684\u6807\u7b7e\u5185\u5bb9\uff0c\u6240\u6709\u8bdd\u9898\u6807\u7b7e\u90fd\u7528tags\u53c2\u6570\u6765\u751f\u6210\u548c\u63d0\u4f9b\u5373\u53ef"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "\u56fe\u7247\u8def\u5f84\u5217\u8868\uff08\u81f3\u5c11\u9700\u89811\u5f20\u56fe\u7247\uff09\u3002\u652f\u6301\u4e24\u79cd\u65b9\u5f0f\uff1a1. HTTP/HTTPS\u56fe\u7247\u94fe\u63a5\uff08\u81ea\u52a8\u4e0b\u8f7d\uff09\uff1b2. \u672c\u5730\u56fe\u7247\u7edd\u5bf9\u8def\u5f84\uff08\u63a8\u8350\uff0c\u5982:/Users/user/image.jpg\uff09"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "\u8bdd\u9898\u6807\u7b7e\u5217\u8868\uff08\u53ef\u9009\u53c2\u6570\uff09\uff0c\u5982 [\u7f8e\u98df, \u65c5\u884c, \u751f\u6d3b]"
        },
        "schedule_at": {
          "type": "string",
          "description": "\u5b9a\u65f6\u53d1\u5e03\u65f6\u95f4\uff08\u53ef\u9009\uff09\uff0cISO8601\u683c\u5f0f\u5982 2024-01-20T10:30:00+08:00\uff0c\u652f\u63011\u5c0f\u65f6\u81f314\u5929\u5185\u3002\u4e0d\u586b\u5219\u7acb\u5373\u53d1\u5e03"
        },
        "is_original": {
          "type": "boolean",
          "description": "\u662f\u5426\u58f0\u660e\u539f\u521b\uff08\u53ef\u9009\uff09\uff0ctrue\u4e3a\u58f0\u660e\u539f\u521b\uff0cfalse\u6216\u4e0d\u586b\u5219\u4e0d\u58f0\u660e"
        },
        "visibility": {
          "type": "string",
          "description": "\u53ef\u89c1\u8303\u56f4\uff08\u53ef\u9009\uff09\uff0c\u652f\u6301: \u516c\u5f00\u53ef\u89c1(\u9ed8\u8ba4)\u3001\u4ec5\u81ea\u5df1\u53ef\u89c1\u3001\u4ec5\u4e92\u5173\u597d\u53cb\u53ef\u89c1\u3002\u4e0d\u586b\u5219\u9ed8\u8ba4\u516c\u5f00\u53ef\u89c1"
        },
        "products": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "\u5546\u54c1\u5173\u952e\u8bcd\u5217\u8868\uff08\u53ef\u9009\uff09\uff0c\u7528\u4e8e\u7ed1\u5b9a\u5e26\u8d27\u5546\u54c1"
        }
      },
      "required": [
        "title",
        "content",
        "images"
      ]
    }
  },
